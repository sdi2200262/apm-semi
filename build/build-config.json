{
  "build": {
    "sourceDir": "templates",
    "outputDir": "dist",
    "cleanOutput": true
  },
  "targets": [
    {
      "id": "copilot",
      "name": "GitHub Copilot",
      "bundleName": "copilot.zip",
      "format": "markdown",
      "configDir": ".github",
      "directories": {
        "commands": ".github/prompts",
        "skills": ".github/skills",
        "guides": ".github/apm-guides",
        "agents": ".github/agents"
      },
      "contextAttachSyntax": "Reference the file using `#file` and select the file from the picker.",
      "newChatGuidance": "Start a new Copilot Chat",
      "subagentGuidance": {
        "hasSubagents": true,
        "toolSyntax": "#runSubagent",
        "explorerName": "exploration",
        "configNote": null
      },
      "postInstallNote": null
    },
    {
      "id": "claude",
      "name": "Claude Code",
      "bundleName": "claude.zip",
      "format": "markdown",
      "configDir": ".claude",
      "directories": {
        "commands": ".claude/commands",
        "skills": ".claude/skills",
        "guides": ".claude/apm-guides",
        "agents": ".claude/agents"
      },
      "contextAttachSyntax": "Reference the file using `@` followed by the file path.",
      "newChatGuidance": "Open a new terminal and start Claude Code",
      "subagentGuidance": {
        "hasSubagents": true,
        "toolSyntax": "Agent(subagent_type=\"Explore\", prompt=\"...\")",
        "explorerName": "Explore",
        "configNote": null
      },
      "postInstallNote": null
    },
    {
      "id": "gemini",
      "name": "Gemini CLI",
      "bundleName": "gemini.zip",
      "format": "toml",
      "configDir": ".gemini",
      "directories": {
        "commands": ".gemini/commands",
        "skills": ".gemini/skills",
        "guides": ".gemini/apm-guides",
        "agents": ".gemini/agents"
      },
      "contextAttachSyntax": "Reference the file using `@` followed by the file path.",
      "newChatGuidance": "Open a new terminal and start Gemini CLI",
      "subagentGuidance": {
        "hasSubagents": true,
        "toolSyntax": "@codebase_investigator <natural language query>",
        "explorerName": "codebase_investigator",
        "configNote": "Requires `experimental.enableAgents: true` in ~/.gemini/settings.json"
      },
      "postInstallNote": "Gemini CLI requires `experimental.enableAgents: true` in ~/.gemini/settings.json for subagent features."
    },
    {
      "id": "cursor",
      "name": "Cursor",
      "bundleName": "cursor.zip",
      "format": "markdown",
      "configDir": ".cursor",
      "directories": {
        "commands": ".cursor/commands",
        "skills": ".cursor/skills",
        "guides": ".cursor/apm-guides",
        "agents": ".cursor/agents"
      },
      "contextAttachSyntax": "Reference the file using `@` and search for the file name.",
      "newChatGuidance": "Start a new Cursor Agent chat",
      "subagentGuidance": {
        "hasSubagents": true,
        "toolSyntax": "Task(subagent_type=\"explore\", prompt=\"...\")",
        "explorerName": "explore",
        "configNote": null
      },
      "postInstallNote": null
    },
    {
      "id": "opencode",
      "name": "OpenCode",
      "bundleName": "opencode.zip",
      "format": "markdown",
      "configDir": ".opencode",
      "directories": {
        "commands": ".opencode/commands",
        "skills": ".opencode/skills",
        "guides": ".opencode/apm-guides",
        "agents": ".opencode/agents"
      },
      "contextAttachSyntax": "Reference the file using `@` followed by the file name.",
      "newChatGuidance": "Open a new terminal and start OpenCode",
      "subagentGuidance": {
        "hasSubagents": true,
        "toolSyntax": "Task(subagent_type=\"explore\", prompt=\"...\")",
        "explorerName": "explore",
        "configNote": null
      },
      "postInstallNote": null
    },
    {
      "id": "codex",
      "name": "Codex CLI",
      "bundleName": "codex.zip",
      "format": "markdown",
      "configDir": ".codex",
      "directories": {
        "commands": ".agents/skills",
        "skills": ".agents/skills",
        "guides": ".codex/apm-guides",
        "agents": ".codex/agents"
      },
      "contextAttachSyntax": "Reference the file using `@` followed by the file path.",
      "newChatGuidance": "Open a new terminal and start Codex CLI",
      "subagentGuidance": {
        "hasSubagents": true,
        "toolSyntax": "spawn_agent(agent_type=\"explorer\", message=\"...\")",
        "explorerName": "explorer",
        "configNote": null
      },
      "postInstallNote": "Codex CLI does not support custom slash commands. APM commands are installed as skills and invoked with the $ prefix (e.g., $apm-1-initiate-planner) instead of /slash-commands."
    }
  ]
}
